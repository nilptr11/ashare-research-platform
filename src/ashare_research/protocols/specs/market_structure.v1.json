{
  "schema": "ashare.protocol_spec.v1",
  "protocol_id": "market_structure.v1",
  "title": "市场结构分析",
  "version": "v1",
  "status": "registered_protocol",
  "description": "按时代产业方向、产业链受益路径、重估环节、龙头验证、高弹性标的、成交趋势确认组织市场结构分析。",
  "required_contexts": [
    "market_structure"
  ],
  "optional_inputs": [
    "industry_context",
    "stock_context",
    "evidence_records",
    "knowledge_snapshot"
  ],
  "suggested_capabilities": [
    "market_environment.v1",
    "theme_strength_detection.v1",
    "concept_membership_discovery.v1"
  ],
  "required_sections": [
    "era_direction",
    "industry_chain",
    "revaluation_segments",
    "leader_validation",
    "elastic_candidates",
    "volume_trend_confirmation"
  ],
  "forbidden": [
    "Do not use reports/runs as factual source",
    "Do not use sources outside the evidence source_type whitelist",
    "Do not issue direct buy/sell advice",
    "Do not state unsupported certainty when evidence or mart data is missing"
  ],
  "output_schema": "ashare.protocol_output.market_structure.v1",
  "gap_policy": {
    "missing_market_data": "block",
    "missing_external_evidence": "degrade_with_gap",
    "missing_knowledge": "warn",
    "missing_intraday_data": "state_no_realtime"
  },
  "quality_gates": [
    "schema_gate",
    "freshness_gate",
    "gap_gate",
    "source_gate",
    "confidence_gate"
  ]
}
