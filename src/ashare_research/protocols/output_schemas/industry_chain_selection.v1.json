{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ashare.protocol_output.industry_chain_selection.v1",
  "title": "Industry Chain Selection Output",
  "type": "object",
  "required": [
    "schema",
    "as_of",
    "question",
    "research_scope",
    "theme_identification",
    "industry_chain_map",
    "revaluation_segments",
    "company_mapping",
    "candidate_pool",
    "evidence_matrix",
    "data_gaps",
    "follow_up_plan",
    "invalid_if",
    "confidence"
  ],
  "properties": {
    "schema": {
      "const": "ashare.protocol_output.industry_chain_selection.v1"
    },
    "as_of": {
      "type": "string",
      "pattern": "^[0-9]{8}$"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "research_scope": {
      "$ref": "#/$defs/research_scope"
    },
    "theme_identification": {
      "$ref": "#/$defs/section"
    },
    "industry_chain_map": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chain_segment"
      }
    },
    "revaluation_segments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/revaluation_segment"
      }
    },
    "company_mapping": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/company_mapping"
      }
    },
    "candidate_pool": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "evidence_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_gap"
      }
    },
    "follow_up_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/follow_up_item"
      }
    },
    "invalid_if": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "research_scope": {
      "type": "object",
      "required": [
        "objective",
        "system_positioning",
        "non_goals",
        "research_states"
      ],
      "properties": {
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "system_positioning": {
          "type": "string",
          "minLength": 1
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "research_states": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "core_research",
              "elastic_watch",
              "laggard_watch",
              "evidence_needed",
              "excluded"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": [
        "summary",
        "facts",
        "inference",
        "confidence"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact_ref"
          }
        },
        "inference": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "chain_segment": {
      "type": "object",
      "required": [
        "segment_id",
        "segment_name",
        "chain_layer",
        "role",
        "prosperity_drivers",
        "constraints",
        "facts",
        "confidence"
      ],
      "properties": {
        "segment_id": {
          "type": "string",
          "minLength": 1
        },
        "segment_name": {
          "type": "string",
          "minLength": 1
        },
        "chain_layer": {
          "type": "string",
          "enum": [
            "upstream",
            "midstream",
            "downstream",
            "equipment",
            "materials",
            "components",
            "manufacturing",
            "application",
            "service",
            "other"
          ]
        },
        "role": {
          "type": "string"
        },
        "prosperity_drivers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact_ref"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "revaluation_segment": {
      "type": "object",
      "required": [
        "segment_id",
        "reason",
        "market_validation",
        "fundamental_validation",
        "risk_flags",
        "confidence"
      ],
      "properties": {
        "segment_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "market_validation": {
          "$ref": "#/$defs/section"
        },
        "fundamental_validation": {
          "$ref": "#/$defs/section"
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "company_mapping": {
      "type": "object",
      "required": [
        "ts_code",
        "name",
        "segments",
        "exposure_level",
        "exposure_evidence",
        "market_validation",
        "fundamental_validation",
        "risk_flags",
        "confidence"
      ],
      "properties": {
        "ts_code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "segments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exposure_level": {
          "type": "string",
          "enum": [
            "core",
            "direct",
            "indirect",
            "weak",
            "unclear"
          ]
        },
        "exposure_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact_ref"
          }
        },
        "market_validation": {
          "$ref": "#/$defs/section"
        },
        "fundamental_validation": {
          "$ref": "#/$defs/section"
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": [
        "ts_code",
        "name",
        "research_state",
        "rationale",
        "evidence_strength",
        "missing_evidence",
        "risk_flags"
      ],
      "properties": {
        "ts_code": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "research_state": {
          "type": "string",
          "enum": [
            "core_research",
            "elastic_watch",
            "laggard_watch",
            "evidence_needed",
            "excluded"
          ]
        },
        "rationale": {
          "type": "string"
        },
        "evidence_strength": {
          "type": "string",
          "enum": [
            "weak",
            "medium",
            "strong"
          ]
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "fact_ref": {
      "type": "object",
      "required": [
        "source_kind",
        "source_id",
        "claim"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "mart",
            "feature",
            "evidence",
            "knowledge",
            "model_inference"
          ]
        },
        "source_id": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "topic",
        "claim",
        "source_kind",
        "source_id",
        "supports",
        "verification",
        "confidence"
      ],
      "properties": {
        "topic": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "mart",
            "feature",
            "evidence",
            "knowledge"
          ]
        },
        "source_id": {
          "type": "string"
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification": {
          "type": "string",
          "enum": [
            "official_single_source",
            "cross_verified",
            "single_source",
            "unverified",
            "stale"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "data_gap": {
      "type": "object",
      "required": [
        "kind",
        "description",
        "impact",
        "recommended_action"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "impact": {
          "type": "string",
          "enum": [
            "block",
            "degrade",
            "warn"
          ]
        },
        "recommended_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "follow_up_item": {
      "type": "object",
      "required": [
        "watch_item",
        "reason",
        "source_plan",
        "priority"
      ],
      "properties": {
        "watch_item": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "source_plan": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
