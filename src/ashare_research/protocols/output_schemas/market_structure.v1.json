{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ashare.protocol_output.market_structure.v1",
  "title": "Market Structure Analysis Output",
  "type": "object",
  "required": [
    "schema",
    "as_of",
    "question",
    "era_direction",
    "industry_chain",
    "revaluation_segments",
    "leader_validation",
    "elastic_candidates",
    "volume_trend_confirmation",
    "supporting_evidence",
    "contradicting_evidence",
    "missing_data",
    "invalid_if",
    "confidence"
  ],
  "properties": {
    "schema": {
      "const": "ashare.protocol_output.market_structure.v1"
    },
    "as_of": {
      "type": "string",
      "pattern": "^[0-9]{8}$"
    },
    "question": {
      "type": "string",
      "minLength": 1
    },
    "era_direction": {
      "$ref": "#/$defs/section"
    },
    "industry_chain": {
      "$ref": "#/$defs/section"
    },
    "revaluation_segments": {
      "$ref": "#/$defs/section"
    },
    "leader_validation": {
      "$ref": "#/$defs/section"
    },
    "elastic_candidates": {
      "$ref": "#/$defs/section"
    },
    "volume_trend_confirmation": {
      "$ref": "#/$defs/section"
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "contradicting_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "missing_data": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/data_gap"
      }
    },
    "invalid_if": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "section": {
      "type": "object",
      "required": [
        "summary",
        "facts",
        "inference",
        "confidence"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "facts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact_ref"
          }
        },
        "inference": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": false
    },
    "fact_ref": {
      "type": "object",
      "required": [
        "source_kind",
        "source_id",
        "claim"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "mart",
            "feature",
            "evidence",
            "knowledge",
            "model_inference"
          ]
        },
        "source_id": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidence_ref": {
      "type": "object",
      "required": [
        "source_kind",
        "source_id",
        "claim"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "evidence",
            "mart",
            "feature",
            "knowledge"
          ]
        },
        "source_id": {
          "type": "string"
        },
        "claim": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "data_gap": {
      "type": "object",
      "required": [
        "kind",
        "description",
        "impact"
      ],
      "properties": {
        "kind": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "impact": {
          "type": "string",
          "enum": [
            "block",
            "degrade",
            "warn"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
