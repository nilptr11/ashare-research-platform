# Tushare Pro SDK token，用于 tushare.pro_api()
TUSHARE_TOKEN=your_tushare_token_here

# 可选：Tushare SDK API 代理地址。留空则使用 SDK 默认地址。
TUSHARE_PROXY_URL=https://your-tushare-proxy.example.com

# 当前 token 对应的积分级别，用于本地调用前权限判断。
TUSHARE_POINTS=15000

# 是否默认允许调用“需单独权限”的接口。false 时需使用 --force。
TUSHARE_ALLOW_SEPARATE_PERMISSION=false

# 可选：本地持久化数据根目录。普通 ashare call 默认写入 $ASHARE_DATA_DIR/tushare。
ASHARE_DATA_DIR=data
